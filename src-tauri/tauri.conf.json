{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tables++",
  "version": "0.5.0",
  "identifier": "com.tablesplusplus.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Tables++",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "theme": "Dark",
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; worker-src 'self' blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Tables++",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/nsimi22/tablesplusplus/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVBNDFFRjA2M0RBQzQxMzkKUldRNVFhdzlCdTlCNmxxTC84YzFWNGYzNmRkY05BZ1JyYXZmdVZGYmdpOUlnaXo2dWxvbmJvZGMK"
    }
  }
}
